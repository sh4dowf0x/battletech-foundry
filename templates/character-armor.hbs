<div class="atow-item-sheet atow-character-armor">
  <header class="sheet-header" style="display:flex; gap:12px; align-items:center;">
    <img
      class="profile-img"
      src="{{item.img}}"
      data-edit="img"
      title="{{item.name}}"
      style="width:72px; height:72px; object-fit:cover; border-radius:10px;" />

    <div style="flex:1; display:flex; flex-direction:column; gap:6px;">
      <input
        name="name"
        type="text"
        value="{{item.name}}"
        placeholder="Armor Name"
        style="font-size:1.3em; font-weight:700;" />

      <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:8px;">
        <div>
          <label style="display:block; opacity:0.8;">Tech</label>
          <input type="text" name="system.ratings.tech" value="{{system.ratings.tech}}" placeholder="A" />
        </div>
        <div>
          <label style="display:block; opacity:0.8;">Legality</label>
          <input type="text" name="system.ratings.legality" value="{{system.ratings.legality}}" placeholder="A" />
        </div>
        <div>
          <label style="display:block; opacity:0.8;">Availability</label>
          <input type="text" name="system.ratings.availability" value="{{system.ratings.availability}}" placeholder="A" />
        </div>
      </div>
    </div>
  </header>

  <hr />

  <section style="display:grid; grid-template-columns: 1fr 1fr; gap:12px;">
    <div>
      <label style="display:block; opacity:0.8;">BAR (M / B / E / X)</label>
      <div style="display:flex; gap:6px; align-items:center;">
        <input type="text" name="system.bar.m" value="{{system.bar.m}}" placeholder="M" style="max-width:80px;" />
        <span style="opacity:0.7;">/</span>
        <input type="text" name="system.bar.b" value="{{system.bar.b}}" placeholder="B" style="max-width:80px;" />
        <span style="opacity:0.7;">/</span>
        <input type="text" name="system.bar.e" value="{{system.bar.e}}" placeholder="E" style="max-width:80px;" />
        <span style="opacity:0.7;">/</span>
        <input type="text" name="system.bar.x" value="{{system.bar.x}}" placeholder="X" style="max-width:80px;" />
      </div>
    </div>

    <div>
      <label style="display:block; opacity:0.8;">Cost / Patch</label>
      <input type="text" name="system.costPatch" value="{{system.costPatch}}" placeholder="e.g. 150 / 10" />
    </div>

    <div>
      <label style="display:block; opacity:0.8;">Type</label>
      <select name="system.type" style="width:100%;">
        {{selectOptions armorTypes selected=system.type}}
      </select>
    </div>

    <div>
      <label style="display:block; opacity:0.8;">AFF</label>
      <input type="text" name="system.affiliation" value="{{system.affiliation}}" placeholder="Faction / Manufacturer" />
    </div>

    <div>
      <label style="display:block; opacity:0.8;">Mass (kg)</label>
      <input type="number" step="0.01" name="system.massKg" value="{{system.massKg}}" placeholder="10" />
    </div>
  </section>

  <hr />

  <section>
    <label style="display:block; opacity:0.8; margin-bottom:6px;">Coverage</label>
    <div style="display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:6px;">
      <label style="display:flex; gap:8px; align-items:center;"><input type="checkbox" name="system.coverage.head" {{checked system.coverage.head}} /> Head</label>
      <label style="display:flex; gap:8px; align-items:center;"><input type="checkbox" name="system.coverage.torso" {{checked system.coverage.torso}} /> Torso</label>
      <label style="display:flex; gap:8px; align-items:center;"><input type="checkbox" name="system.coverage.arms" {{checked system.coverage.arms}} /> Arms</label>
      <label style="display:flex; gap:8px; align-items:center;"><input type="checkbox" name="system.coverage.legs" {{checked system.coverage.legs}} /> Legs</label>
      <label style="display:flex; gap:8px; align-items:center;"><input type="checkbox" name="system.coverage.hands" {{checked system.coverage.hands}} /> Hands</label>
      <label style="display:flex; gap:8px; align-items:center;"><input type="checkbox" name="system.coverage.feet" {{checked system.coverage.feet}} /> Feet</label>
    </div>
  </section>

  <hr />

  <section>
    <label style="display:block; opacity:0.8; margin-bottom:6px;">Notes</label>
    <textarea
      name="system.notes"
      rows="6"
      style="width:100%;"
      placeholder="Special rules / effects / limitations">{{system.notes}}</textarea>
  </section>
</div>
