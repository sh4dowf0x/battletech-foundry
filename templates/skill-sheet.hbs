<div class="{{cssClass}} atow-item-shell" autocomplete="off">
  <section
    class="atow-item-hero"
    role="presentation"
    style="display:grid; grid-template-columns:minmax(96px, 25%) minmax(0, 1fr); gap:12px; align-items:start;">
    <div style="min-width:96px; max-width:120px;">
      <img
        class="atow-item-art"
        src="{{item.img}}"
        data-edit="img"
        title="{{item.name}}"
        style="width:100%; aspect-ratio:1 / 1; height:auto; display:block;" />
    </div>

    <div class="atow-item-hero-main" style="display:flex; flex-direction:column; gap:8px; min-width:0;">
      <div class="atow-item-kicker">Character Skill Profile</div>

      <div class="atow-item-title">
        <input name="name" type="text" value="{{item.name}}" placeholder="Skill Name" />
      </div>

      <div class="atow-item-meta-grid" style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:6px;">
        <div class="atow-field">
          <label>Default TN</label>
          <select name="system.tn">
            {{#each tnOptions as |tn|}}
              <option value="{{tn}}" {{#ifEq tn ../selected.tn}}selected{{/ifEq}}>{{tn}}</option>
            {{/each}}
          </select>
        </div>

        <div class="atow-field">
          <label>XP</label>
          <input name="system.xp" type="number" value="{{system.xp}}" />
        </div>
      </div>
    </div>
  </section>

  <section class="atow-card atow-stat-card">
    <div class="atow-stat-table-wrap">
      <table class="atow-stat-table">
        <tr>
          <th>Link 1</th>
          <th>Link 2</th>
          <th>Legacy Link</th>
        </tr>
        <tr>
          <td>
            <select name="system.linkedAttribute1">
              {{#each attributeOptions as |a|}}
                <option value="{{a.value}}" {{#ifEq a.value ../selected.linkedAttribute1}}selected{{/ifEq}}>{{a.label}}</option>
              {{/each}}
            </select>
          </td>
          <td>
            <select name="system.linkedAttribute2">
              {{#each attributeOptions as |a|}}
                <option value="{{a.value}}" {{#ifEq a.value ../selected.linkedAttribute2}}selected{{/ifEq}}>{{a.label}}</option>
              {{/each}}
            </select>
          </td>
          <td>
            <input type="text" value="{{selected.linkedAttribute1}}" disabled />
          </td>
        </tr>
      </table>
    </div>
  </section>

  <section class="atow-item-layout compact">
    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field">
          <label class="atow-compact-label">Notes</label>
          <textarea
            class="short"
            name="system.notes"
            rows="6"
            placeholder="Usage notes, examples, or situational guidance.">{{system.notes}}</textarea>
        </div>
      </section>
    </div>

    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field-grid compact-2">
          <div class="atow-field">
            <label class="atow-compact-label">Primary Link</label>
            <input type="text" value="{{selected.linkedAttribute1}}" disabled />
          </div>

          <div class="atow-field">
            <label class="atow-compact-label">Secondary Link</label>
            <input type="text" value="{{selected.linkedAttribute2}}" disabled />
          </div>
        </div>
      </section>
    </div>
  </section>
</div>
