<div class="{{cssClass}} atow-item-shell" autocomplete="off">
  <section
    class="atow-item-hero"
    role="presentation"
    style="display:grid; grid-template-columns:minmax(96px, 25%) minmax(0, 1fr); gap:12px; align-items:start;">
    <div style="min-width:96px; max-width:120px;">
      <img
        class="atow-item-art"
        src="{{item.img}}"
        data-edit="img"
        title="{{item.name}}"
        style="width:100%; aspect-ratio:1 / 1; height:auto; display:block;" />
    </div>

    <div class="atow-item-hero-main" style="display:flex; flex-direction:column; gap:8px; min-width:0;">
      <div class="atow-item-kicker">BattleMech Weapon Profile</div>

      <div class="atow-item-title">
        <input name="name" type="text" value="{{item.name}}" placeholder="Weapon Name" />
      </div>

      <div class="atow-item-meta-grid" style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:6px;">
        <div class="atow-field">
          <label>Ammo Type</label>
          <input name="system.ammoType" type="text" value="{{system.ammoType}}" placeholder="N/A / SRM / AC/5 / Gauss" />
        </div>

        <div class="atow-field">
          <label>Manufacturer</label>
          <input name="system.manufacturer" type="text" value="{{system.manufacturer}}" placeholder="Defiance / Magna / Diverse Optics" />
        </div>
      </div>
    </div>
  </section>

  <section class="atow-card atow-stat-card">
    <div class="atow-stat-table-wrap">
      <table class="atow-stat-table">
        <tr>
          <th>Type</th>
          <th>Heat</th>
          <th>Dmg</th>
          <th>Min</th>
          <th>Short</th>
          <th>Med</th>
          <th>Long</th>
          <th>Tons</th>
          <th>Crits</th>
        </tr>
        <tr>
          <td><input name="system.dmgType" type="text" value="{{system.dmgType}}" /></td>
          <td><input name="system.heat" type="number" value="{{system.heat}}" min="0" /></td>
          <td><input name="system.damage" type="number" value="{{system.damage}}" min="0" /></td>
          <td><input name="system.range.min" type="number" value="{{system.range.min}}" min="0" /></td>
          <td><input name="system.range.short" type="number" value="{{system.range.short}}" min="0" /></td>
          <td><input name="system.range.medium" type="number" value="{{system.range.medium}}" min="0" /></td>
          <td><input name="system.range.long" type="number" value="{{system.range.long}}" min="0" /></td>
          <td><input name="system.tonnage" type="number" value="{{system.tonnage}}" min="0" step="0.5" /></td>
          <td><input name="system.critSlots" type="number" value="{{system.critSlots}}" min="1" /></td>
        </tr>
      </table>
    </div>
  </section>

  <section class="atow-item-layout compact">
    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-inline-field">
          <label>Rapid Fire</label>
          <div class="atow-inline-field-input">
            <input name="system.rapidFire" type="number" value="{{system.rapidFire}}" min="1" max="20" />
          </div>
        </div>
      </section>

      <section class="atow-card">
        <div class="atow-field">
          <label class="atow-compact-label">Special Rules</label>
          <textarea class="short" name="system.specialRules" rows="5">{{system.specialRules}}</textarea>
        </div>
      </section>
    </div>

    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field">
          <label class="atow-compact-label">Notes</label>
          <textarea class="short" name="system.notes" rows="5">{{system.notes}}</textarea>
        </div>
      </section>
    </div>
  </section>
</div>
