<div class="{{cssClass}} atow-item-shell" autocomplete="off">
  <section
    class="atow-item-hero"
    role="presentation"
    style="display:grid; grid-template-columns:minmax(96px, 25%) minmax(0, 1fr); gap:12px; align-items:start;">
    <div style="min-width:96px; max-width:120px;">
      <img
        class="atow-item-art"
        src="{{item.img}}"
        data-edit="img"
        title="{{item.name}}"
        style="width:100%; aspect-ratio:1 / 1; height:auto; display:block;" />
    </div>

    <div class="atow-item-hero-main" style="display:flex; flex-direction:column; gap:8px; min-width:0;">
      <div class="atow-item-kicker">Character Equipment Profile</div>

      <div class="atow-item-title">
        <input name="name" type="text" value="{{item.name}}" placeholder="Equipment Name" />
      </div>

      <div class="atow-item-meta-grid" style="display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:6px;">
        <div class="atow-field">
          <label>Type</label>
          <select name="system.gearType">
            {{selectOptions gearTypeOptions selected=system.gearType labelAttr="label" valueAttr="value" localize=false}}
          </select>
        </div>

        <div class="atow-field">
          <label>Equipped</label>
          <input type="checkbox" name="system.equipped" {{checked system.equipped}} />
        </div>

        <div class="atow-field">
          <label>Class</label>
          <input type="text" value="{{gearTypeLabel}}" disabled />
        </div>
      </div>
    </div>
  </section>

  <section class="atow-card atow-stat-card">
    <div class="atow-stat-table-wrap">
      <table class="atow-stat-table">
        <tr>
          <th>Tech</th>
          <th>Avail</th>
          <th>Legal</th>
          <th>Cost</th>
          <th>Kg</th>
          <th>PPH</th>
          <th>Range</th>
        </tr>
        <tr>
          <td><input type="text" name="system.ratings.tech" value="{{system.ratings.tech}}" placeholder="A" /></td>
          <td><input type="text" name="system.ratings.availability" value="{{system.ratings.availability}}" placeholder="A" /></td>
          <td><input type="text" name="system.ratings.legality" value="{{system.ratings.legality}}" placeholder="L" /></td>
          <td><input type="number" name="system.costCbills" value="{{system.costCbills}}" min="0" step="1" /></td>
          <td><input type="number" name="system.massKg" value="{{system.massKg}}" min="0" step="0.1" /></td>
          <td><input type="number" name="system.powerUsePph" value="{{system.powerUsePph}}" min="0" step="0.1" /></td>
          <td><input type="text" name="system.range" value="{{system.range}}" placeholder="-" /></td>
        </tr>
      </table>
    </div>
  </section>

  <section class="atow-item-layout compact">
    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field">
          <label class="atow-compact-label">Notes</label>
          <textarea class="short" name="system.notes" rows="6" placeholder="Usage notes, special handling, or narrative details.">{{system.notes}}</textarea>
        </div>
      </section>
    </div>

    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field">
          <label class="atow-compact-label">Field Notes</label>
          <textarea class="short" name="system.description" rows="6" placeholder="Broader description or catalog details.">{{system.description}}</textarea>
        </div>
      </section>
    </div>
  </section>
</div>
