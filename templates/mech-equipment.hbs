<form class="{{cssClass}} mech-equipment" autocomplete="off">
  <header class="sheet-header">
    <img class="profile" src="{{item.img}}" data-edit="img" title="{{item.name}}" height="64" width="64"/>
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Equipment Name"/>
      </h1>
    </div>
  </header>

  <section class="sheet-body">
    <fieldset>
      <legend>Mech Equipment</legend>

      <div class="form-group">
        <label>Crit Slots</label>
        <input name="system.critSlots" type="number" value="{{system.critSlots}}" min="1" />
      </div>

      <div class="form-group">
        <label>Tonnage (tons)</label>
        <input name="system.tonnage" type="number" value="{{system.tonnage}}" min="0" step="0.5" />
      </div>

      <div class="form-group">
        <label>Ammo Type</label>
        <select name="system.ammoType">
          {{selectOptions ammoTypeOptions selected=system.ammoType}}
        </select>
      </div>

      <div class="form-group">
        <label>Ammo Amount</label>
        <input name="system.ammoAmount" type="number" value="{{system.ammoAmount}}" min="0" />
      </div>

      <div class="form-group">
        <label>Heat Dissipation</label>
        <input name="system.heatDissipation" type="number" value="{{system.heatDissipation}}" min="0" />
      </div>
    </fieldset>

    <fieldset>
      <legend>Notes</legend>
      <textarea name="system.notes" rows="6">{{system.notes}}</textarea>
    </fieldset>
  </section>
</form>
