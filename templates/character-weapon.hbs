<div class="{{cssClass}} atow-item-shell" autocomplete="off">
  <section
    class="atow-item-hero"
    role="presentation"
    style="display:grid; grid-template-columns:minmax(96px, 25%) minmax(0, 1fr); gap:12px; align-items:start;">
    <div style="min-width:96px; max-width:120px;">
      <img
        class="atow-item-art"
        src="{{item.img}}"
        data-edit="img"
        title="{{item.name}}"
        style="width:100%; aspect-ratio:1 / 1; height:auto; display:block;" />
    </div>

    <div class="atow-item-hero-main" style="display:flex; flex-direction:column; gap:8px; min-width:0;">
      <div class="atow-item-kicker">Character Weapon Profile</div>

      <div class="atow-item-title">
        <input name="name" type="text" value="{{item.name}}" placeholder="Weapon Name" />
      </div>

      <div class="atow-item-meta-grid" style="display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:6px;">
        <div class="atow-field">
          <label>Tech</label>
          <input type="text" name="system.ratings.tech" value="{{system.ratings.tech}}" placeholder="A" />
        </div>

        <div class="atow-field">
          <label>Legality</label>
          <input type="text" name="system.ratings.legality" value="{{system.ratings.legality}}" placeholder="L" />
        </div>

        <div class="atow-field">
          <label>Availability</label>
          <input type="text" name="system.ratings.availability" value="{{system.ratings.availability}}" placeholder="A" />
        </div>
      </div>
    </div>
  </section>

  <section class="atow-card atow-stat-card">
    <div class="atow-stat-table-wrap">
      <table class="atow-stat-table">
        <tr>
          <th>AP</th>
          <th>BD</th>
          <th>Range</th>
          <th>Shots</th>
          <th>Cost / Reload</th>
          <th>AFF</th>
          <th>Skill</th>
        </tr>
        <tr>
          <td><input type="text" name="system.damage.ap" value="{{system.damage.ap}}" placeholder="AP" /></td>
          <td><input type="text" name="system.damage.bd" value="{{system.damage.bd}}" placeholder="BD" /></td>
          <td><input type="text" name="system.range" value="{{system.range}}" placeholder="1m / 5m / 10m" /></td>
          <td><input type="text" name="system.shots" value="{{system.shots}}" placeholder="- / 6 / 30" /></td>
          <td><input type="text" name="system.costReload" value="{{system.costReload}}" placeholder="25" /></td>
          <td><input type="text" name="system.affiliation" value="{{system.affiliation}}" placeholder="Faction / Maker" /></td>
          <td>
            <select name="system.skillKey">
              {{selectOptions skillChoices selected=system.skillKey localize=false}}
            </select>
          </td>
        </tr>
      </table>
    </div>
  </section>

  <section class="atow-item-layout compact">
    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field-grid compact-2">
          <div class="atow-field">
            <label class="atow-compact-label">Weapon Mass (kg)</label>
            <input type="number" step="0.01" name="system.mass.weaponKg" value="{{system.mass.weaponKg}}" placeholder="4" />
          </div>

          <div class="atow-field">
            <label class="atow-compact-label">Reload Mass (kg)</label>
            <input type="number" step="0.01" name="system.mass.reloadKg" value="{{system.mass.reloadKg}}" placeholder="-" />
          </div>
        </div>

        <div class="atow-field" style="margin-top:10px;">
          <label class="atow-compact-label">Skill Tie</label>
          <input type="text" value="{{skillTied}}" disabled />
        </div>
      </section>
    </div>

    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field">
          <label class="atow-compact-label">Notes</label>
          <textarea
            class="short"
            name="system.notes"
            rows="6"
            placeholder="Special rules, reload quirks, or attack modifiers.">{{system.notes}}</textarea>
        </div>
      </section>
    </div>
  </section>
</div>
