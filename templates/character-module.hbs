<form class="atow-item-sheet atow-module-sheet" autocomplete="off">
  <header class="sheet-header">
    <h1 class="item-name">
      <input name="name" type="text" value="{{item.name}}" placeholder="Module Name" {{#unless isGM}}disabled{{/unless}} />
    </h1>
    <div class="sheet-subheader">
      <div class="field">
        <label>Type</label>
        <select name="system.moduleType" {{#unless isGM}}disabled{{/unless}}>
          <option value="affiliation" {{#ifEq system.moduleType "affiliation"}}selected{{/ifEq}}>Affiliation</option>
          <option value="earlyChildhood" {{#ifEq system.moduleType "earlyChildhood"}}selected{{/ifEq}}>Early Childhood</option>
          <option value="lateChildhood" {{#ifEq system.moduleType "lateChildhood"}}selected{{/ifEq}}>Late Childhood</option>
          <option value="higherEducation" {{#ifEq system.moduleType "higherEducation"}}selected{{/ifEq}}>Higher Education</option>
          <option value="realLife" {{#ifEq system.moduleType "realLife"}}selected{{/ifEq}}>Real Life</option>
        </select>
      </div>

      <div class="field">
        <label>Module Cost (XP Spent)</label>
        <input name="system.moduleCost" type="number" value="{{system.moduleCost}}" {{#unless isGM}}disabled{{/unless}} />
      </div>
    </div>
  </header>

  <section class="sheet-body">

    <section class="panel">
      <h2>Description</h2>
      <textarea name="system.description" rows="5" {{#unless isGM}}disabled{{/unless}}>{{system.description}}</textarea>
    </section>

    <section class="panel">
      <h2>Prerequisites</h2>
      <div class="grid-2">
        <div class="field">
          <label>Required Affiliation</label>
          <input name="system.prereq.affiliation" type="text" value="{{system.prereq.affiliation}}" placeholder="any" {{#unless isGM}}disabled{{/unless}} />
          <p class="hint">Use <b>any</b> to allow any affiliation, or an exact match to the Character’s Affiliation field.</p>
        </div>

        <div class="field">
          <label>Attribute Requirements (one per line)</label>
          <textarea name="system.prereq.attributesText" rows="5" placeholder="STR>=3&#10;INT>=2" {{#unless isGM}}disabled{{/unless}}>{{system.prereq.attributesText}}</textarea>
          <p class="hint">Format: <code>STR&gt;=3</code>, <code>BOD&gt;=2</code>, etc.</p>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2>Fixed XP Grants</h2>
      <div class="grid-3">
        <div class="field">
          <label>Attributes (one per line)</label>
          <textarea name="system.fixed.attributesText" rows="8" placeholder="STR 100&#10;BOD 100&#10;INT -25" {{#unless isGM}}disabled{{/unless}}>{{system.fixed.attributesText}}</textarea>
          <p class="hint">Examples: <code>STR 100</code>, <code>INT -25</code>, <code>RFL (+75 XP)</code></p>
        </div>

        <div class="field">
          <label>Traits (one per line)</label>
          <textarea name="system.fixed.traitsText" rows="8" placeholder="Fit 100&#10;Illiterate -75" {{#unless isGM}}disabled{{/unless}}>{{system.fixed.traitsText}}</textarea>
          <p class="hint">Tracked as XP pools by Trait name (does not auto-create Trait Items yet).</p>
        </div>

        <div class="field">
          <label>Skills (one per line)</label>
          <textarea name="system.fixed.skillsText" rows="8" placeholder="Running 10&#10;Survival/Any 15" {{#unless isGM}}disabled{{/unless}}>{{system.fixed.skillsText}}</textarea>
          <p class="hint">Tracked as XP pools by Skill name (does not auto-create Skill Items yet).</p>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2>Flexible XP</h2>
      <div class="grid-2">
        <div class="field">
          <label>XP Amount (per pick)</label>
          <input name="system.flexible.amount" type="number" value="{{system.flexible.amount}}" {{#unless isGM}}disabled{{/unless}} />
        </div>

        <div class="field">
          <label>Number of Picks</label>
          <input name="system.flexible.picks" type="number" value="{{system.flexible.picks}}" min="0" {{#unless isGM}}disabled{{/unless}} />
        </div>
      </div>

      <div class="checks">
        <label><input type="checkbox" name="system.flexible.allowAttributes" {{#if system.flexible.allowAttributes}}checked{{/if}} {{#unless isGM}}disabled{{/unless}} /> Attributes</label>
        <label><input type="checkbox" name="system.flexible.allowTraits" {{#if system.flexible.allowTraits}}checked{{/if}} {{#unless isGM}}disabled{{/unless}} /> Traits</label>
        <label><input type="checkbox" name="system.flexible.allowSkills" {{#if system.flexible.allowSkills}}checked{{/if}} {{#unless isGM}}disabled{{/unless}} /> Skills</label>
      </div>

      <p class="hint">When the module is added to a character, you’ll be prompted to allocate each pick.</p>
    </section>

    {{#unless isGM}}
      <p class="sheet-note"><b>Read-only:</b> Character Modules can be viewed by players, but only edited by the GM.</p>
    {{/unless}}

  </section>
</form>
