<div class="{{cssClass}} atow-item-shell" autocomplete="off">
  <section
    class="atow-item-hero"
    role="presentation"
    style="display:grid; grid-template-columns:minmax(96px, 25%) minmax(0, 1fr); gap:12px; align-items:start;">
    <div style="min-width:96px; max-width:120px;">
      <img
        class="atow-item-art"
        src="{{item.img}}"
        data-edit="img"
        title="{{item.name}}"
        style="width:100%; aspect-ratio:1 / 1; height:auto; display:block;" />
    </div>

    <div class="atow-item-hero-main" style="display:flex; flex-direction:column; gap:8px; min-width:0;">
      <div class="atow-item-kicker">Character Trait Profile</div>

      <div class="atow-item-title">
        <input name="name" type="text" value="{{item.name}}" placeholder="Trait Name" />
      </div>

      <div class="atow-item-meta-grid" style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:6px;">
        <div class="atow-field">
          <label>Category</label>
          <input name="system.category" type="text" value="{{system.category}}" placeholder="Advantage / Disadvantage" />
        </div>

        <div class="atow-field">
          <label>Status</label>
          <input type="text" value="{{#if trait.active}}Active{{else}}Inactive{{/if}}" disabled />
        </div>
      </div>
    </div>
  </section>

  <section class="atow-card atow-stat-card">
    <div class="atow-stat-table-wrap">
      <table class="atow-stat-table">
        <tr>
          <th>TP</th>
          <th>Trait XP</th>
          <th>Threshold</th>
          <th>Notes</th>
        </tr>
        <tr>
          <td><input name="system.tp" type="number" value="{{trait.tp}}" /></td>
          <td><input name="system.cost" type="number" value="{{trait.xp}}" /></td>
          <td><input type="number" value="{{trait.threshold}}" disabled /></td>
          <td><input name="system.notes" type="text" value="{{system.notes}}" placeholder="Optional" /></td>
        </tr>
      </table>
    </div>
  </section>

  <section class="atow-item-layout compact">
    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field">
          <label class="atow-compact-label">Description</label>
          <textarea
            name="system.description"
            rows="8"
            placeholder="Trait rules text, activation details, and narrative context.">{{system.description}}</textarea>
        </div>
      </section>
    </div>

    <div class="atow-stack">
      <section class="atow-card">
        <div class="atow-field-grid compact-2">
          <div class="atow-field">
            <label class="atow-compact-label">Activation</label>
            <input type="text" value="{{#if trait.active}}Threshold reached{{else}}Threshold not reached{{/if}}" disabled />
          </div>

          <div class="atow-field">
            <label class="atow-compact-label">Rule</label>
            <input type="text" value="Active at TP × 100 XP" disabled />
          </div>
        </div>
      </section>
    </div>
  </section>
</div>
