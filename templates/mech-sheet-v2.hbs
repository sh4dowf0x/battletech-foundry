<div class="mech-col mech-col-3">
  <section class="panel armor-panel">
    <h3>Armor Diagram</h3>

    <div class="armor-summary">
      <label>Total Armor Factor:</label>
      <span><b>{{armorSummary.current}}</b> / {{armorSummary.max}}</span>
      <span class="armor-allowed">(Allowed: {{armorSummary.allowed}})</span>
    </div>

    <div class="armor-controls">
      {{#each armorLocList as |loc|}}
        <div class="armor-control">
          <label>{{loc.label}}</label>
          <input class="armor-max" name="system.armor.{{loc.key}}.max" type="number" value="{{loc.max}}" min="0" />
        </div>
      {{/each}}
    </div>

    <div class="armor-diagram">
      {{#each armorLocList as |loc|}}
        <div class="armor-loc armor-loc-{{loc.key}}" data-armor-loc="{{loc.key}}">
          {{#each loc.pips as |p|}}
            <span class="armor-pip {{#if p.filled}}filled{{/if}}" data-loc="{{loc.key}}" data-pip="{{p.n}}"></span>
          {{/each}}
        </div>
      {{/each}}
    </div>

    <div class="armor-hint">
      Click pips to mark damage (filled = damage taken). Edit the number field to set pip count for each location.
    </div>
  </section>


<section class="panel structure-panel">
  <h3>Internal Structure</h3>

  <div class="structure-controls">
    {{#each structureLocList as |loc|}}
      <div class="structure-control">
        <label>{{loc.label}}</label>
        <span class="move-pill">{{loc.max}}</span>
      </div>
    {{/each}}
  </div>

  <div class="structure-diagram">
    {{#each structureLocList as |loc|}}
      <div class="structure-loc structure-loc-{{loc.key}}" data-structure-loc="{{loc.key}}">
        {{#each loc.pips as |p|}}
          <span class="structure-pip {{#if p.filled}}filled{{/if}}" data-loc="{{loc.key}}" data-pip="{{p.n}}"></span>
        {{/each}}
      </div>
    {{/each}}
  </div>

  <div class="structure-hint">
    Click pips to mark structure damage (filled = damage taken). Structure points are derived from tonnage.
  </div>
</section>

  <section class="panel tonnage-panel">
    <h3>Mass Budget</h3>

    <table class="tonnage-table">
      <thead>
        <tr>
          <th>Component</th>
          <th class="tons">Tons</th>
          <th>Notes</th>
        </tr>
      </thead>

      <tbody>
        {{#each tonnageBreakdown as |row|}}
          <tr>
            <td>{{row.label}}</td>
            <td class="tons">{{row.display}}</td>
            <td class="note">{{row.note}}</td>
          </tr>
        {{/each}}
      </tbody>

      <tfoot>
        <tr>
          <td><strong>Total</strong></td>
          <td class="tons"><strong>{{mechWeight.current}}t</strong></td>
          <td class="note">
            {{#if mechWeight.over}}
              OVER by {{mechWeight.overBy}}t
            {{else}}
              Remaining {{mechWeight.remaining}}t
            {{/if}}
          </td>
        </tr>
      </tfoot>
    </table>
  </section>

</div>

<div class="bottom-panels">
  <section class="panel status-panel">
    <h3>Condition Alerts</h3>

    <div class="status-list">
      {{#each statusEntries as |s|}}
        <div class="status-item status-{{s.level}}">
          <span class="status-icon">{{s.icon}}</span>
          <div>
            <div class="status-text">{{s.text}}</div>
            {{#if s.detail}}
              <span class="status-detail">{{s.detail}}</span>
            {{/if}}
          </div>
        </div>
      {{/each}}
    </div>
  </section>
</div>

</div>
</section>
