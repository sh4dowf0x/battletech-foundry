<form class="{{cssClass}} mech-sheet mech-sheet-v2{{#if hideThirdColumn}} third-column-hidden{{/if}}" autocomplete="off">
  <style>
    /* ------------------------------------------------------------
       AToW Battletech | Crit Slot Facelift
       Scoped to .mech-sheet so it won't bleed into other sheets.
       ------------------------------------------------------------ */
    .mech-sheet .crit-slots {
      gap: 4px;
    }

    .mech-sheet .crit-slot {
      position: relative;
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 4px 6px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 6px;
      background: rgba(0, 0, 0, 0.35);
      min-height: 28px;
      overflow: hidden;
    }

    .mech-sheet .crit-slot.occupied {
      background: rgba(20, 20, 20, 0.55);
    }

    .mech-sheet .crit-slot.destroyed {
      filter: grayscale(0.35);
    }

    .mech-sheet .crit-slot .crit-num {
      width: 20px;
      text-align: right;
      font-size: 11px;
      opacity: 0.7;
      flex: 0 0 auto;
    }

    .mech-sheet .crit-slot .crit-icon {
      width: 16px;
      text-align: center;
      opacity: 0.85;
      flex: 0 0 auto;
    }

    .mech-sheet .crit-slot .crit-text {
      flex: 1 1 auto;
      min-width: 0;
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }

    .mech-sheet .crit-slot .crit-name {
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ------------------------------------------------------------
       Armor controls compacting + summary header
       ------------------------------------------------------------ */
    .mech-sheet .armor-summary {
      margin: 4px 0 8px 0;
    }

    .mech-sheet .armor-summary .armor-allowed {
      opacity: 0.8;
      margin-left: 6px;
    }

    .mech-sheet .armor-controls {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px 10px;
      margin-bottom: 6px;
    }

    .mech-sheet .armor-control {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 6px;
    }

    .mech-sheet .armor-control label {
      font-size: 11px;
      opacity: 0.95;
      margin: 0;
    }

    .mech-sheet input.armor-max {
      width: 48px;
      height: 22px;
      padding: 0 4px;
      font-size: 12px;
    }

    .mech-sheet .crit-slot .crit-name.continuation {
      font-size: 11px;
      font-weight: 400;
      opacity: 0.5;
    }

    .mech-sheet .crit-slot .crit-tag {
      font-size: 10px;
      opacity: 0.65;
    }

    .mech-sheet .crit-slot.destroyed .crit-name {
      text-decoration: line-through;
      opacity: 0.55;
    }

    .mech-sheet .crit-slot .crit-clear,
    .mech-sheet .crit-slot .crit-destroy {
      position: absolute;
      top: 3px;
      width: 18px;
      height: 18px;
      display: grid;
      place-items: center;
      border-radius: 4px;
      background: rgba(0, 0, 0, 0.55);
      border: 1px solid rgba(255, 255, 255, 0.14);
      opacity: 0;
      transition: opacity 120ms ease;
      cursor: pointer;
      user-select: none;
    }

    .mech-sheet .crit-slot .crit-clear { right: 3px; }
    .mech-sheet .crit-slot .crit-destroy { right: 24px; }

    .mech-sheet .crit-slot:hover .crit-clear,
    .mech-sheet .crit-slot:hover .crit-destroy {
      opacity: 1;
    }

    /* Category accents (inset strip on the left) */
    .mech-sheet .crit-slot.crit-cat-weapon { box-shadow: inset 3px 0 0 rgba(200, 90, 70, 0.9); }
    .mech-sheet .crit-slot.crit-cat-ammo { box-shadow: inset 3px 0 0 rgba(90, 150, 200, 0.9); }
    .mech-sheet .crit-slot.crit-cat-heatsink { box-shadow: inset 3px 0 0 rgba(160, 160, 160, 0.85); }
    .mech-sheet .crit-slot.crit-cat-jumpjet { box-shadow: inset 3px 0 0 rgba(180, 120, 220, 0.85); }
    .mech-sheet .crit-slot.crit-cat-artemis { box-shadow: inset 3px 0 0 rgba(200, 120, 220, 0.9); }
    .mech-sheet .crit-slot.crit-cat-engine { box-shadow: inset 3px 0 0 rgba(230, 170, 70, 0.9); }
    .mech-sheet .crit-slot.crit-cat-gyro { box-shadow: inset 3px 0 0 rgba(230, 200, 90, 0.9); }
    .mech-sheet .crit-slot.crit-cat-actuator { box-shadow: inset 3px 0 0 rgba(120, 200, 140, 0.9); }
    .mech-sheet .crit-slot.crit-cat-cockpit,
    .mech-sheet .crit-slot.crit-cat-lifesupport,
    .mech-sheet .crit-slot.crit-cat-sensors,
    .mech-sheet .crit-slot.crit-cat-system { box-shadow: inset 3px 0 0 rgba(120, 120, 120, 0.85); }
    .mech-sheet .crit-slot.crit-cat-empty { box-shadow: inset 3px 0 0 rgba(80, 80, 80, 0.35); opacity: 0.75; }

/* Tonnage breakdown table */
.mech-sheet .tonnage-panel .tonnage-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
.mech-sheet .tonnage-panel .tonnage-table th,
.mech-sheet .tonnage-panel .tonnage-table td {
  padding: 4px 6px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.mech-sheet .tonnage-panel .tonnage-table th {
  text-align: left;
  opacity: 0.85;
  font-weight: 600;
}
.mech-sheet .tonnage-panel .tonnage-table td.tons,
.mech-sheet .tonnage-panel .tonnage-table th.tons {
  text-align: right;
  width: 90px;
  white-space: nowrap;
}
.mech-sheet .tonnage-panel .tonnage-table td.note {
  opacity: 0.8;
  font-size: 11px;
}
.mech-sheet .tonnage-panel .tonnage-table tfoot td {
  border-bottom: none;
  padding-top: 6px;
}

/* Bottom panels layout (Tonnage + Status side-by-side) */
.mech-sheet .bottom-panels {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 10px;
  align-items: start;
}

/* Status panel */
.mech-sheet .status-panel .status-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.mech-sheet .status-panel .status-item {
  display: grid;
  grid-template-columns: 22px 1fr;
  gap: 8px;
  align-items: start;
  padding: 6px 8px;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  background: rgba(0,0,0,0.25);
}

.mech-sheet .status-panel .status-icon {
  width: 22px;
  text-align: center;
  opacity: 0.9;
}

.mech-sheet .status-panel .status-text {
  font-size: 12px;
  font-weight: 600;
  line-height: 1.2;
}

.mech-sheet .status-panel .status-detail {
  display: block;
  margin-top: 2px;
  font-size: 11px;
  opacity: 0.78;
  font-weight: 400;
}

/* Visual flair: warnings/critical pulse */
.mech-sheet .status-panel .status-warning {
  border-color: rgba(255, 90, 90, 0.55);
  box-shadow: inset 3px 0 0 rgba(255, 80, 80, 0.85);
}

.mech-sheet .status-panel .status-critical {
  border-color: rgba(255, 50, 50, 0.75);
  box-shadow: inset 3px 0 0 rgba(255, 35, 35, 0.95);
  animation: atowStatusPulse 1.05s ease-in-out infinite;
}

.mech-sheet .status-panel .status-warning .status-text,
.mech-sheet .status-panel .status-critical .status-text {
  color: rgba(255, 120, 120, 0.98);
}

@keyframes atowStatusPulse {
  0%, 100% { filter: brightness(1.0); }
  50% { filter: brightness(1.45); }
}
  </style>
  <header class="sheet-header">
    <div class="header-title">
      <input class="name" name="name" type="text" value="{{actor.name}}" placeholder="Mech Name"/>
    </div>
    <div class="header-meta">
      {{#each mechHeaderMeta as |tag|}}
        <span>{{tag}}</span>
      {{/each}}
    </div>
    <div class="header-actions">
      <button
        type="button"
        class="header-action-btn{{#if isDazzleMode}} is-active{{/if}}"
        data-header-action="dazzle"
        data-macro-label="Dazzle Mode"
        data-macro-img="icons/magic/light/projectile-beam-yellow.webp"
        draggable="true">Dazzle Mode</button>
      <button
        type="button"
        class="header-action-btn"
        data-header-action="jump"
        data-macro-label="Jump"
        data-macro-img="icons/svg/wing.svg"
        draggable="true">Jump</button>
      <button
        type="button"
        class="header-action-btn{{#if isManualShutdown}} is-active{{/if}}"
        data-header-action="shutdown"
        data-macro-label="{{#if isManualShutdown}}Startup{{else}}Shutdown{{/if}}"
        data-macro-img="systems/atow-battletech/assets/status/shutdown.svg"
        draggable="true">
        {{#if isManualShutdown}}Startup{{else}}Shutdown{{/if}}
      </button>
    </div>
  </header>

  <section class="sheet-body">
    <div class="mech-layout">
      {{!-- =========================================================
           COLUMN 1
           ========================================================= --}}
      <div class="mech-main">
        <div class="mech-main-top">
<div class="mech-col mech-col-1">
        <section class="panel mech-data-panel">
          <h3>BattleMech Data</h3>

          <div class="info-grid">
            {{!-- Row 1: Type + Tonnage --}}
            <div class="info-row">
              <div class="info-field">
                <label>Type</label>
                <div class="inline">
                  <input name="system.mech.chassis" type="text" value="{{system.mech.chassis}}" placeholder="Chassis"/>
                  <input name="system.mech.model" type="text" value="{{system.mech.model}}" placeholder="Model"/>
                </div>
              </div>

              <div class="info-field">
                <label>Tonnage</label>
                <select name="system.mech.tonnage">
                  {{selectOptions tonnageOptions selected=mechTonnage}}
                </select>
	              </div>
	            </div>

	            {{!-- Row 1b: BV + Year Produced --}}
	            <div class="info-row">
	              <div class="info-field">
	                <label>BV</label>
	                <input name="system.mech.bv" type="number" value="{{system.mech.bv}}" min="0" placeholder="0"/>
	              </div>

	              <div class="info-field">
	                <label>Year Produced</label>
	                <input name="system.mech.yearProduced" type="number" value="{{system.mech.yearProduced}}" min="0" placeholder="3025"/>
	              </div>
	            </div>

            {{!-- Row 2: Tech Base + Rules Level --}}
            <div class="info-row">
              <div class="info-field">
                <label>Tech Base</label>
                <input name="system.mech.techBase" type="text" value="{{system.mech.techBase}}" placeholder="Inner Sphere / Clan"/>
              </div>

              <div class="info-field">
                <label>Rules Level</label>
                <input name="system.mech.rulesLevel" type="text" value="{{system.mech.rulesLevel}}" placeholder="Standard"/>
              </div>
            </div>

            {{!-- Row 3: Role + Engine Type --}}
            <div class="info-row">
              <div class="info-field">
                <label>Role</label>
                <input name="system.mech.role" type="text" value="{{system.mech.role}}" placeholder="Scout"/>
              </div>

              <div class="info-field">
                <label>Engine Type</label>
                <input name="system.mech.engine" type="text" value="{{system.mech.engine}}" placeholder="e.g. 160 Fusion"/>
              </div>
            </div>

            {{!-- Row 4: Movement + (spacer for now) --}}
            <div class="info-row">
              <div class="info-field">
                <label>Movement</label>
                <div class="movement-stack">
                  <div class="inline movement">
                    <span class="mini-label">W</span>
                    <input name="system.movement.walk" type="number" value="{{system.movement.walk}}" readonly data-tooltip="Derived from Engine Rating / Tonnage" />
                    <span class="mini-label">R</span>
                    <input name="system.movement.run" type="number" value="{{system.movement.run}}" readonly data-tooltip="Derived from Engine Rating / Tonnage" />
                    <span class="mini-label">J</span>
                    <input name="system.movement.jump" type="number" value="{{system.movement.jump}}" readonly data-tooltip="Derived from Engine Rating / Tonnage" />
                  </div>
                  <div class="movement-status-row">
                    <span class="mini-label">This Turn</span>
                    <span class="mini-label">Moved</span>
                    <span class="move-pill">{{movementStatus.moved}}</span>
                    <span class="mini-label">MP</span>
                    <span class="move-pill">{{movementStatus.mpSpent}}</span>
                    <span class="mini-label">Mode</span>
                    <span class="move-pill">{{movementStatus.mode}}</span>
                  </div>
                </div>
              </div>
              <div class="info-field spacer"></div>
            </div>
          </div>
        </section>

        <section class="panel loadout-panel">
          <h3>Combat Loadout</h3>

          {{!-- Drag/drop target --}}
          <div class="drop-zone" data-drop-zone="loadout">
            <div class="we-table">
              <div class="we-row we-header">
                <div class="we-col type">Type</div>
                <div class="we-col loc">Loc</div>
                <div class="we-col ht">Ht</div>
                <div class="we-col dmg">Dmg</div>
                <div class="we-col range">Range</div>
              </div>

              {{#each loadout as |item|}}
                <div class="we-row"
                  {{#if item.id}}data-item-id="{{item.id}}"{{/if}}
                  {{#if item.itemUuid}}data-item-uuid="{{item.itemUuid}}"{{/if}}
                  {{#if item.weaponFireKey}}data-weapon-fire-key="{{item.weaponFireKey}}"{{/if}}
                  {{#if item.itemUuid}}draggable="true"{{/if}}
                  {{#if item.firedThisTurn}}data-fired="true"{{/if}}
                  data-destroyed="{{item.destroyed}}">
                  <div class="we-col type"><span class="we-name">{{item.name}}</span></div>
                  <div class="we-col loc">{{item.system.loc}}</div>
                  <div class="we-col ht">{{item.system.heat}}</div>
                  <div class="we-col dmg">{{item.system.damage}}</div>
                  <div class="we-col range">
                    {{#if item.system.range.min}}{{item.system.range.min}}{{else}}{{item.system.min}}{{/if}}/{{#if item.system.range.short}}{{item.system.range.short}}{{else}}{{item.system.sht}}{{/if}}/{{#if item.system.range.medium}}{{item.system.range.medium}}{{else}}{{item.system.med}}{{/if}}/{{#if item.system.range.long}}{{item.system.range.long}}{{else}}{{item.system.lng}}{{/if}}
                  </div>
                </div>
              {{/each}}
            </div>

            <div class="loadout-subsection">
              <h4>Ammunition Bins</h4>

              {{#if hasAmmoBins}}
                <div class="ammo-table">
                  <div class="ammo-row ammo-header">
                    <div class="ammo-col type">Type</div>
                    <div class="ammo-col cur">Current</div>
                    <div class="ammo-col tot">Total</div>
                  </div>

                  {{#each ammoBins as |bin|}}
                    <div class="ammo-row" data-ammo-key="{{bin.key}}">
                      <div class="ammo-col type">{{bin.name}}</div>
                      <div class="ammo-col cur">
                        <input name="system.ammoBins.{{bin.key}}.current" type="number" value="{{bin.current}}" min="0" max="{{bin.total}}" />
                      </div>
                      <div class="ammo-col tot">
                        <span class="ammo-total">{{bin.total}}</span>
                      </div>
                    </div>
                  {{/each}}
                </div>
              {{else}}
                <div class="ammo-empty">No ammo bins detected in crit slots.</div>
              {{/if}}
            </div>
          </div>
        </section>
      </div>

      {{!-- =========================================================
     COLUMN 2
     ========================================================= --}}
<div class="mech-col mech-col-2">
  <section class="panel warrior-data">
    <h3>Pilot Station</h3>

    <div class="wd-row">
      <label>Name</label>
      <input name="system.pilot.name" type="text" value="{{pilot.name}}" placeholder="Pilot Name"/>
    </div>

    <div class="wd-row wd-two">
      <div class="wd-field">
        <label>Gunnery Skill</label>
        <input name="system.pilot.gunnery" type="number" value="{{pilot.gunnery}}" />
      </div>

      <div class="wd-field">
        <label class="rollable" data-formula="2d6 + @pilot.piloting" data-label="Piloting Check">Piloting Skill</label>
        <input name="system.pilot.piloting" type="number" value="{{pilot.piloting}}" />
      </div>
    </div>

    <div class="wd-row">
      <label>Hits Taken</label>
      <div class="track track-hits">
        {{#each pilotTracks.hits as |b|}}
          <div class="track-box {{#if b.filled}}filled{{/if}}" data-track="hitsTaken" data-value="{{b.n}}">
            {{b.n}}
          </div>
        {{/each}}
      </div>
    </div>

    <div class="wd-row">
      <label>Consciousness#</label>
      <div class="track track-consciousness">
        {{#each pilotTracks.consciousness as |c|}}
          <div class="track-box {{#if c.active}}active{{/if}}" data-track="consciousness" data-value="{{c.v}}">
            {{c.v}}
          </div>
        {{/each}}
      </div>
    </div>
  </section>

  <section class="panel mech-portrait-panel">
    <h3>Profile</h3>
    {{#if isProfileVideo}}
      <video class="mech-portrait-img mech-portrait-media" src="{{profileImage}}" autoplay loop muted playsinline disablepictureinpicture title="{{actor.name}}"></video>
    {{else}}
      <img class="mech-portrait-img mech-portrait-media" src="{{profileImage}}" data-edit="img" title="{{actor.name}}"/>
    {{/if}}
  </section>

  <section class="panel heat-panel">
    <h3>Thermal Load</h3>

    <div class="heat-meta">
      <div class="heat-field">
        <label>Heat</label>
        <div class="inline">
          <input name="system.heat.value" type="number" value="{{heatData.current}}" min="0" max="{{heatData.max}}" />
          <span class="mini-label">/</span>
          <input name="system.heat.max" type="number" value="{{heatData.max}}" min="1" />
        </div>
      </div>

      <div class="heat-field">
        <label>Heat Sinks</label>
        <div class="inline">
          <span class="move-pill">{{heatData.baseSinks}}</span>
          <span class="mini-label">+{{heatData.extraSinks}}</span>
          <span class="mini-label">=</span>
          <span class="move-pill">{{heatData.totalSinks}}</span>
          <span class="mini-label">| Cooling</span>
          <span class="move-pill">{{heatData.dissipation}}</span>
        </div>
      </div>

{{#if heatData.engineSinksAdjustable}}
<div class="heat-field">
  <label>Engine Sinks Used</label>
  <div class="inline">
    <input type="range"
           min="{{heatData.engineSinksMin}}"
           max="{{heatData.engineSinksAuto}}"
           step="1"
           value="{{heatData.engineSinksUsed}}"
           data-engine-sinks-slider />
    <input class="engine-sinks-number"
           type="number"
           name="system.heat.engineSinks"
           min="{{heatData.engineSinksMin}}"
           max="{{heatData.engineSinksAuto}}"
           step="1"
           value="{{heatData.engineSinksUsed}}"
           data-engine-sinks-number />
    <span class="mini-label">/ {{heatData.engineSinksAuto}} (auto)</span>
    {{#if heatData.engineSinksRemoved}}
      <span class="mini-label">| Removed {{heatData.engineSinksRemoved}}</span>
    {{/if}}
  </div>
</div>
{{/if}}

      <div class="heat-field">
        <label>Double Heat Sinks</label>
        <div class="inline">
          <input type="checkbox" name="system.heat.isDouble" {{checked system.heat.isDouble}} />
          <span class="mini-label">{{#if system.heat.isDouble}}DHS (2x cooling){{else}}SHS{{/if}}</span>
        </div>
      </div>

      <div class="heat-field">
        <label>Unvented / Effects</label>
        <div class="inline">
          <span class="move-pill">{{heatData.unvented}}</span>
          <span class="mini-label">|</span>
          <span class="mini-label">Move -{{heatData.movePenalty}}</span>
          <span class="mini-label">|</span>
          <span class="mini-label">Fire {{signed heatData.fireMod}}</span>
        </div>
        {{#if heatData.shutdown}}
          <div class="hint">SHUTDOWN (heat). Attacks are blocked until cleared (restart logic TBD).</div>
        {{/if}}
        {{#if heatData.shutdownInfo.roll}}
          <div class="hint">Shutdown check: rolled {{heatData.shutdownInfo.roll}} vs avoid {{heatData.shutdownInfo.avoidTN}} (heat {{heatData.shutdownInfo.heat}})</div>
        {{/if}}
      </div>
    </div>

    <div class="heat-scale" title="Click to set heat">
      {{#each heatData.scale as |p|}}
        <span class="heat-pip {{#if p.filled}}filled{{/if}}" data-pip="{{p.n}}"></span>
      {{/each}}
    </div>
  </section>
</div>

{{!-- =========================================================
           COLUMN 3 (empty for now)
           ========================================================= --}}
        </div>

{{!-- =========================================================
     CRITICAL HIT TABLE (Bottom Section)
     ========================================================= --}}
<section class="panel crit-panel">
  <h3>Critical Grid</h3>

  <div class="crit-grid">
    <div class="crit-col crit-left">
      {{#each crit.left as |loc|}}
        {{!-- crit location block --}}
{{#with loc as |L|}}
  <div class="crit-loc">
    <div class="crit-loc-title">{{L.label}} {{#if L.allowCASE}}<a class="crit-add-case" data-loc="{{L.key}}" title="Add CASE to first empty crit slot">+CASE</a>{{/if}}</div>

    <div class="crit-loc-body">
      {{#if L.simple}}
        <div class="crit-slots simple">
          {{#each L.slots as |s|}}
  <div class="crit-slot drop-zone crit-cat-{{s.category}} {{#if s.hasItem}}occupied{{/if}} {{#if s.isStart}}span-start{{/if}} {{#if s.continuation}}continuation{{/if}} {{#if s.destroyed}}destroyed{{/if}}"
       data-drop-zone="crit"
       data-crit-loc="{{L.key}}"
       data-crit-index="{{s.index}}"
       data-part-of="{{s.partOf}}"
       style="{{#if s.isStart}}grid-row: span {{s.span}};{{/if}}">
    <span class="crit-num">{{s.num}}</span>
    <span class="crit-icon"><i class="{{s.iconClass}}"></i></span>
    <div class="crit-text">
      {{#if s.continuation}}
        <div class="crit-name continuation">&#x21B3;</div>
      {{else}}
        <div class="crit-name">{{s.displayName}}</div>
        {{#if s.slotTag}}<div class="crit-tag">{{s.slotTag}}</div>{{/if}}
      {{/if}}
    </div>
    <input type="hidden" name="system.crit.{{L.key}}.slots.{{s.index}}.label" value="{{s.label}}" />
    {{#if s.isStart}}
      {{#if s.hasItem}}
        <a class="crit-destroy" title="{{#if s.destroyed}}Restore{{else}}Mark Destroyed{{/if}}">
          {{#if s.destroyed}}🛠{{else}}💥{{/if}}
        </a>
      {{/if}}
      {{#if s.uuid}}
        <a class="crit-clear" title="Remove">✕</a>
      {{/if}}
    {{/if}}
  </div>
{{/each}}
        </div>
      {{else}}
        <div class="crit-band">
          <div class="crit-band-label">1-3</div>
          <div class="crit-slots">
            {{#each L.band13 as |s|}}
